{
  "name": "@acme/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "clean": "git clean -xdf .cache .turbo node_modules src/generated",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit"
  },
  "dependencies": {
    "kysely": "0.28.17",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/typescript": "workspace:*",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "prisma": "^7.8.0",
    "prisma-kysely": "^3.1.0",
    "typescript": "~6.0.3"
  }
}
