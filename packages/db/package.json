{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate",
    "clean": "git clean -xdf .cache .turbo node_modules src/generated",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit"
  },
  "dependencies": {
    "kysely": "0.28.17",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.5.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prisma": "^7.8.0",
    "prisma-kysely": "^3.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
