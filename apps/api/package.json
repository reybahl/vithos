{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "with-env": "dotenv -e .env --",
    "dev": "pnpm with-env tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "start": "pnpm with-env node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@repo/hono-app": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "hono": "^4.12.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript": "workspace:*",
    "@types/node": "^25.9.1",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3"
  }
}
