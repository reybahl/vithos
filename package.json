{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check \"**/*.{ts,tsx,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "turbo": "^2.9.6",
    "wrangler": "^4.88.0"
  },
  "packageManager": "pnpm@8.15.6",
  "name": "vithos-stack",
  "lint-staged": {
    "*.{ts,tsx,md}": ["prettier --write"]
  }
}
