{
  "name": "vithos",
  "private": true,
  "scripts": {
    "build": "turbo run build --ui=stream",
    "dev": "turbo run dev",
    "lint": "turbo run lint --ui=stream",
    "typecheck": "turbo run typecheck --ui=stream",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "postinstall": "pnpm db:generate",
    "db:generate": "pnpm --filter @acme/db run db:generate",
    "db:migrate": "pnpm --filter @acme/db run db:migrate",
    "db:migrate:deploy": "pnpm --filter @acme/db run db:migrate:deploy"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "turbo": "^2.9.14",
    "typescript": "~7.0.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,mts,cts,jsx,json,css,scss,md,mdx,yml,yaml,html}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@8.15.6",
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  }
}
