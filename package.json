{
  "private": true,
  "scripts": {
    "build": "turbo run build --ui=stream",
    "dev": "turbo run dev --filter=!worker",
    "lint": "turbo run lint --ui=stream",
    "typecheck": "turbo run typecheck --ui=stream",
    "format": "prettier --check \"**/*.{js,mjs,cjs,ts,tsx,mts,cts,jsx,json,css,scss,md,mdx,yml,yaml,html}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,ts,tsx,mts,cts,jsx,json,css,scss,md,mdx,yml,yaml,html}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "postinstall": "pnpm db:generate",
    "db:generate": "pnpm --filter @acme/db run db:generate",
    "db:migrate:deploy": "pnpm --filter @acme/db run db:migrate:deploy"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@8.15.6",
  "name": "vithos-stack",
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,mts,cts,jsx,json,css,scss,md,mdx,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  }
}
